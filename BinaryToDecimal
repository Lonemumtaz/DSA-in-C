#include <stdio.h>

int main() {
    int binary, decimal = 0, base = 1, rem;

    printf("Enter a binary number: ");
    scanf("%d", &binary);

    while (binary > 0) {
        rem = binary % 10;        // Get last digit
        decimal = decimal + rem * base;  
        base = base * 2;          // Increase base (2^n)
        binary = binary / 10;     // Remove last digit
    }

    printf("Decimal = %d", decimal);
    return 0;
}